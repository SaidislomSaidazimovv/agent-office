{
  "name": "agent-office",
  "displayName": "Agent Office 3D",
  "description": "A realistic 3D office where your Claude Code agents come to life as animated characters",
  "version": "0.1.0",
  "publisher": "agent-office",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/SaidislomSaidazimovv/agent-office"
  },
  "engines": {
    "vscode": "^1.84.0"
  },
  "extensionKind": [
    "workspace"
  ],
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "agent-office.showPanel",
        "title": "Agent Office: Show Panel"
      },
      {
        "command": "agent-office.installHooks",
        "title": "Agent Office: Claude Hook'larini o'rnatish"
      },
      {
        "command": "agent-office.uninstallHooks",
        "title": "Agent Office: Claude Hook'larini olib tashlash"
      },
      {
        "command": "agent-office.showDiagnostics",
        "title": "Agent Office: Diagnostikани ko'rsatish"
      }
    ],
    "viewsContainers": {
      "panel": [
        {
          "id": "agent-office-panel",
          "title": "Agent Office",
          "icon": "$(window)"
        }
      ]
    },
    "views": {
      "agent-office-panel": [
        {
          "type": "webview",
          "id": "agent-office.panelView",
          "name": "Agent Office"
        }
      ]
    },
    "configuration": {
      "title": "Agent Office",
      "properties": {
        "agent-office.autoShowPanel": {
          "type": "boolean",
          "default": false,
          "description": "VS Code ochilganda Agent Office panelини avtomatik ochish."
        },
        "agent-office.autoSpawnAgent": {
          "type": "boolean",
          "default": false,
          "description": "VS Code ochilganда, agar hech qanday agent ishlamayotgan bo'lsa, avtomatik bittasini ishga tushirish."
        },
        "agent-office.hooksEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Claude Code Hooks orqali ishonchli aniqlash (~/.claude/settings.json'ga hook qo'shadi). O'chirilsa faqat JSONL kuzatuvи ishlaydi."
        }
      }
    }
  },
  "scripts": {
    "check-types": "tsc -p tsconfig.json",
    "build:extension": "node esbuild.mjs",
    "build:webview": "npm --prefix webview-ui run build",
    "build": "npm run check-types && npm run build:extension && npm run build:webview",
    "test": "esbuild test/run.ts --bundle --platform=node --format=cjs --outfile=.test-out.cjs --log-level=error && node .test-out.cjs",
    "watch:extension": "node esbuild.mjs --watch",
    "install:all": "npm install && npm --prefix webview-ui install",
    "package": "npm run build && vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.84.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0"
  }
}
