# ── agent-office: environment settings ──────────────────────────────
# Copy this file to `.env` (or `.env.local`) and adjust as needed.
# All Vite-exposed vars must be prefixed with VITE_.

# Data source that drives the 3D office.
#   sim = local fake simulation (default, no backend required)
#   ws  = real backend over WebSocket (stub until the backend lands)
VITE_SOURCE=sim

# WebSocket backend URL. Used only when VITE_SOURCE=ws.
VITE_WS_URL=ws://localhost:8787
